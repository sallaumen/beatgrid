# Copy to .env and fill in. Never commit .env.

# Soundcharts API — legacy auth headers (x-app-id / x-api-key). Free tier =
# 1,000 requests — spend carefully (resolution is dedup-aware and cached forever).
SOUNDCHARTS_APP_ID=
SOUNDCHARTS_API_KEY=

# Anthropic API key. Only needed for the AnthropicApi AI adapter. The default AI
# adapter shells out to the `claude` CLI (your Claude login), which needs no key.
ANTHROPIC_API_KEY=

# Override the library root (defaults to ~/Music/DJ).
LIBRARY_ROOT=
