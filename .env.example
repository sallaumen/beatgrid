# Copy to .env and fill in. Never commit .env.

# Soundcharts API. Use the sandbox credentials in dev/test; real credentials only
# for production resolution runs. Free tier = 1,000 requests total — spend carefully.
SOUNDCHARTS_APP_ID=
SOUNDCHARTS_API_KEY=

# Anthropic API key. Only needed for the AnthropicApi AI adapter. The default AI
# adapter shells out to the `claude` CLI (your Claude login), which needs no key.
ANTHROPIC_API_KEY=

# Override the library root (defaults to ~/Music/DJ).
LIBRARY_ROOT=
