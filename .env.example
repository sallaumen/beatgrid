# Copy to .env and fill in. Never commit .env.

# Soundcharts API (OAuth client_credentials). The app authenticates by POSTing
# APP_ID:API_KEY (Basic auth) + team_id to the token endpoint, then uses the
# returned Bearer token. Free tier = 1,000 requests total — spend carefully.
# APP_ID = Client ID, API_KEY = API secret, TEAM_ID = the team slug (JWT "tid").
SOUNDCHARTS_APP_ID=
SOUNDCHARTS_API_KEY=
SOUNDCHARTS_TEAM_ID=

# Anthropic API key. Only needed for the AnthropicApi AI adapter. The default AI
# adapter shells out to the `claude` CLI (your Claude login), which needs no key.
ANTHROPIC_API_KEY=

# Override the library root (defaults to ~/Music/DJ).
LIBRARY_ROOT=
